# Get your Place ID from: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Get from Facebook Developer Portal -> Instagram Graph API
# Long-lived token (valid 60 days, refresh before expiry)
INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_token_here
